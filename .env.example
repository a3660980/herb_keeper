# Remote Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Optional but recommended for Vercel/custom domains.
# Example: https://herbkeeper.vercel.app or https://app.your-domain.com
NEXT_PUBLIC_SITE_URL=

# Preferred publishable key name used by this repo today.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Optional alternate public key name for the browser and SSR client.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy alias. Leave blank if you already use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Used by Supabase CLI when pushing migrations or seed data to the linked remote DB.
SUPABASE_DB_PASSWORD=

# Optional. Only needed for privileged server-side operations.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Playwright E2E registration/login flow uses these credentials.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Optional. Defaults to "Playwright 測試帳號" when omitted.
E2E_USER_FULL_NAME=
